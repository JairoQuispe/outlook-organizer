{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "outlook-organizer",
  "version": "0.1.0",
  "identifier": "com.jairoquispe.outlook-organizer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "outlook-organizer",
        "width": 800,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "scripts-ps1/*"
    ]
  }
}
